---
# ============================================================
# Kubernetes Secret — generated by Ansible from vault variables
# ============================================================
# This template is rendered by the k8s_deploy role using
# secrets decrypted from Ansible Vault at deploy time.
# The secrets never exist in plaintext on disk or in Git.
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: turf-app-secrets
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/part-of: turf-booking-platform
    app.kubernetes.io/managed-by: ansible
type: Opaque
stringData:
  JWT_SECRET: "{{ app_jwt_secret }}"
  SESSION_SECRET: "{{ app_session_secret }}"
  GOOGLE_CLIENT_ID: "{{ app_google_client_id }}"
  GOOGLE_CLIENT_SECRET: "{{ app_google_client_secret }}"
  MONGO_ROOT_USERNAME: "{{ app_mongo_root_username }}"
  MONGO_ROOT_PASSWORD: "{{ app_mongo_root_password }}"
