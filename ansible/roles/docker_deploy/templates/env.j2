# ============================================================
# Environment file — generated by Ansible from vault variables
# ============================================================
# This file is rendered at deploy time using secrets decrypted
# from Ansible Vault. It is never committed to version control.
# ============================================================

# JWT Secret (shared across auth, turf, and booking services)
JWT_SECRET={{ app_jwt_secret }}

# Session secret for auth service
SESSION_SECRET={{ app_session_secret }}

# Google OAuth (auth service only)
GOOGLE_CLIENT_ID={{ app_google_client_id }}
GOOGLE_CLIENT_SECRET={{ app_google_client_secret }}
